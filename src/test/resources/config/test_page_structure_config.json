{
  "space_key": "DEV",
  "projects": [
    {
      "gitlab_project_id": 1,
      "gitlab_path": "test-group/test-project",
      "confluence_parent_pages": ["프로젝트", "테스트 프로젝트"],
      "pages": [
        {
          "id": "service_overview",
          "title": "서비스 개요 및 구성도",
          "auto_generate": true,
          "prompt_template": "service_overview",
          "trigger": ["push", "merge_request"],
          "target_files": ["README.md", "docker-compose.yml", "*.config.js"]
        },
        {
          "id": "api_spec",
          "title": "API 명세서",
          "auto_generate": true,
          "prompt_template": "api_spec",
          "trigger": ["push", "merge_request"],
          "target_files": ["**/controllers/**", "**/routes/**"]
        },
        {
          "id": "db_schema",
          "title": "DB 스키마",
          "auto_generate": true,
          "prompt_template": "db_schema",
          "trigger": ["push"],
          "target_files": ["**/models/**", "*.sql"]
        }
      ]
    }
  ],
  "branches": {
    "trigger_branches": ["main", "develop"],
    "ignore_branches": ["feature/*", "hotfix/*", "release/*"]
  },
  "options": {
    "skip_keyword": "[skip-doc]",
    "overwrite_manual_edits": false
  }
}
